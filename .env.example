# ══════════════════════════════════════════════════════════════════════════════
#  OpenSRE — Environment Configuration
#  Copy this file: cp .env.example .env
#  Only ANTHROPIC_API_KEY is required. All channels are optional.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM provider ────────────────────────────────────────────────────────────
# Which backend powers root-cause analysis, self-critique, and post-mortems.
# Options: anthropic (default) | openai | google
LLM_PROVIDER=anthropic

# ── Anthropic (default provider) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...
OPENSRE_MODEL=claude-sonnet-4-6

# ── OpenAI / OpenAI-compatible (only if LLM_PROVIDER=openai) ──────────────────
# Works with OpenAI, Azure OpenAI, Groq, Together, OpenRouter, or a local
# Ollama / vLLM server. Point OPENAI_BASE_URL at the compatible endpoint.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=                       # e.g. http://localhost:11434/v1 for Ollama

# ── Google Gemini (only if LLM_PROVIDER=google) ──────────────────────────────
# GOOGLE_API_KEY=...                     # or GEMINI_API_KEY
# GEMINI_MODEL=gemini-2.0-flash


# ── Notification Channels (configure at least one, or use console fallback) ──

# ── Slack ─────────────────────────────────────────────────────────────────────
# How to get tokens: https://api.slack.com/apps
#   1. Create app → Enable Socket Mode → Get SLACK_APP_TOKEN (xapp-...)
#   2. Add OAuth scopes: chat:write, channels:read → Install to workspace
#   3. Copy Bot User OAuth Token as SLACK_BOT_TOKEN (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_ALERT_CHANNEL=#incidents

# ── Telegram ──────────────────────────────────────────────────────────────────
# How to get tokens:
#   1. Message @BotFather on Telegram → /newbot → copy the token
#   2. Add your bot to a group/channel and make it an admin
#   3. Get chat_id: visit https://api.telegram.org/bot<TOKEN>/getUpdates
#      after sending a message in the group — look for "chat":{"id":...}
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ── WhatsApp (via Twilio) ─────────────────────────────────────────────────────
# How to get credentials:
#   1. Create free account at https://www.twilio.com
#   2. Console → Messaging → Try it out → Send a WhatsApp message (Sandbox)
#   3. Connect your WhatsApp to sandbox: send the join code shown in console
#   4. Copy Account SID and Auth Token from https://console.twilio.com
#
# Sandbox number (free, for testing):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
#
# Comma-separated recipient numbers (international format with whatsapp: prefix)
WHATSAPP_ALERT_NUMBERS=whatsapp:+91XXXXXXXXXX,whatsapp:+1XXXXXXXXXX


# ── Monitor Thresholds ────────────────────────────────────────────────────────
CPU_THRESHOLD_PCT=85
MEMORY_THRESHOLD_PCT=90
SLOW_QUERY_THRESHOLD_MS=500
POLL_INTERVAL_SECONDS=30

# How long (seconds) to suppress duplicate alerts for the same metric+host
# Default: 300 seconds (5 minutes)
ALERT_COOLDOWN_SECONDS=300


# ── Simulation mode (true = no real AWS/K8s/DB needed) ────────────────────────
SIMULATION_MODE=true


# ── Storage ────────────────────────────────────────────────────────────────────
OPENSRE_DB_PATH=opensre_incidents.db
# PostgreSQL URL — only needed when SIMULATION_MODE=false
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb


# ── AWS (optional, only when SIMULATION_MODE=false) ────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
