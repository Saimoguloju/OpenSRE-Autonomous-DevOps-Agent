# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Slack (optional — console output used if not set) ──────
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_ALERT_CHANNEL=#incidents

# ── Thresholds ─────────────────────────────────────────────
CPU_THRESHOLD_PCT=85
MEMORY_THRESHOLD_PCT=90
SLOW_QUERY_THRESHOLD_MS=500
POLL_INTERVAL_SECONDS=30

# ── Simulation mode (true = no real AWS/K8s/DB needed) ─────
SIMULATION_MODE=true

# ── AWS (optional, only when SIMULATION_MODE=false) ────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Storage ────────────────────────────────────────────────
OPENSRE_DB_PATH=opensre_incidents.db
OPENSRE_MODEL=claude-sonnet-4-6
