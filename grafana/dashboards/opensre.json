{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "OpenSRE — Autonomous DevOps Agent",
  "tags": ["opensre", "sre", "incidents"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Active Incidents",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(opensre_active_incidents)", "legendFormat": "open" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Incidents Detected (rate by severity)",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (severity) (rate(opensre_incidents_total[5m]))",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "type": "piechart",
      "title": "Incidents by Status",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (opensre_incidents_total)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "MTTR — Incident Resolution Time (p50 / p90)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(opensre_incident_resolution_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(opensre_incident_resolution_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Approval Latency (p90)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(opensre_approval_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Analysis Latency (p90)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(opensre_claude_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Remediation Action Duration (p90)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(opensre_action_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        }
      ]
    }
  ],
  "__inputs": [],
  "__requires": []
}
